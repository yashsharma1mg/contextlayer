{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Context Layer",
	"version": "0.1.0",
	"identifier": "design.contextlayer.desktop",
	"build": {
		"beforeBuildCommand": "bun run prepare:bundle",
		"frontendDist": "../src"
	},
	"app": {
		"windows": [
			{
				"title": "Context Layer",
				"width": 1440,
				"height": 900,
				"minWidth": 960,
				"minHeight": 640,
				"resizable": true
			}
		],
		"security": {
			"csp": "default-src 'self'; connect-src http://127.0.0.1:31420; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
		}
	},
	"bundle": {
		"active": true,
		"targets": ["app"],
		"externalBin": [
			"binaries/context-agent",
			"binaries/studio",
			"binaries/prototype-compiler",
			"binaries/media-extractor"
		],
		"resources": [
			"resources/migrations",
			"resources/studio",
			"resources/postgres"
		],
		"macOS": {
			"minimumSystemVersion": "13.0"
		}
	}
}
