# Postgres connection string (Supabase project's pooled connection string, pgvector extension enabled)
DATABASE_URL=

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:8787
STUDIO_URL=http://localhost:3000
# Required in production. Use a distinct high-entropy value from Better Auth.
CONNECTION_ENCRYPTION_KEY=
CONNECTOR_POLLING=false

# Embeddings — NVIDIA NIM (nv-embedqa-e5-v5, build.nvidia.com)
NVIDIA_API_KEY=

# Chat/RAG — OpenRouter (model swappable, no OpenAI)
OPENROUTER_API_KEY=
OPENROUTER_CHAT_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free

# Confluence OAuth (2.0, 3LO) — from the Atlassian Developer Console
CONFLUENCE_CLIENT_ID=
CONFLUENCE_CLIENT_SECRET=
CONFLUENCE_REDIRECT_URI=http://localhost:8787/api/connections/confluence/callback

# Figma OAuth — from figma.com/developers/apps
FIGMA_CLIENT_ID=
FIGMA_CLIENT_SECRET=
FIGMA_REDIRECT_URI=http://localhost:8787/api/connections/figma/callback
OPENROUTER_FALLBACK_MODEL=nvidia/nemotron-3-super-120b-a12b:free
