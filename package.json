{
  "name": "contextlayer",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "format-lint": "bunx biome check --write",
    "check-types": "turbo run check-types",
    "db:generate": "cd packages/db && bunx drizzle-kit generate",
    "db:migrate": "cd packages/db && bunx drizzle-kit migrate"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@ai-sdk/openai": "^2.0.42",
    "@hono/zod-validator": "^0.7.1",
    "@scalar/hono-api-reference": "^0.9.11",
    "ai": "^5.0.59",
    "better-auth": "^1.3.3",
    "dedent": "^1.6.0",
    "drizzle-orm": "^0.44.3",
    "drizzle-zod": "~0.7.1",
    "hono": "^4.6.0",
    "hono-openapi": "^0.4.8",
    "nanoid": "^5.1.5",
    "pg": "^8.16.3",
    "pino": "^9.7.0",
    "postgres": "^3.4.7",
    "resend": "^4.7.0",
    "zod": "^3.25.76",
    "zod-openapi": "^4.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@total-typescript/tsconfig": "^1.0.4",
    "@types/pg": "^8.15.4",
    "drizzle-kit": "^0.31.4",
    "turbo": "^2.5.4",
    "typescript": "5.8.3"
  },
  "overrides": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}
